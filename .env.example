# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Local development                                                       ║
# ║                                                                          ║
# ║  Choose ONE data source: JSON dump (easiest) or live database.           ║
# ║  Everything else in this section is optional for local dev.              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Option A: JSON dump (no database or Vercel credentials needed)
# Download a DB dump release, unzip it, and point this to the directory.
# See README for setup instructions.
# DUMP_DIR=./inferencex-dump/inferencex-dump-2026-03-30

# Option B: Live database
# Neon PostgreSQL read replica (pooled, HTTP-compatible)
# DATABASE_READONLY_URL=

# GitHub PAT (optional) — improves rate limits for star count and workflow metadata
# Create at: https://github.com/settings/personal-access-tokens
# GITHUB_TOKEN=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Production deployment (Vercel)                                          ║
# ║                                                                          ║
# ║  All variables below are required for production.                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Database read replica (pooled, HTTP-compatible)
DATABASE_READONLY_URL=

# Vercel Blob storage (caches large API responses)
BLOB_CACHE_PREFIX=
BLOB_READ_WRITE_TOKEN=

# GitHub PAT for star count, workflow metadata
GITHUB_TOKEN=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Database administration (DO NOT SHARE)                                  ║
# ║                                                                          ║
# ║  Only needed for running DB scripts (migrate, ingest, reset, etc).      ║
# ║  Not needed for running the app.                                         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Database primary writer (unpooled, direct connection)
DATABASE_WRITE_URL=

# Cache invalidation secret (triggers purge after data changes)
INVALIDATE_SECRET=
