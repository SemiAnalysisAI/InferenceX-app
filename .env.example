# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Required for all contributors (local development)                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Your PAT for GitHub API requests (scoped for API access only)
# Create at: https://github.com/settings/personal-access-tokens
# Used by for star count, workflow metadata, etc
GITHUB_TOKEN=

# Blob storage prefix
# Used by Next.js API routes to cache big responses in blob storage
BLOB_CACHE_PREFIX=

# Blob storage read/write token
# Used by Next.js API routes to read/write from blob storage for caching
BLOB_READ_WRITE_TOKEN=

# Database read replica (pooled)
# Used by Next.js API routes for all database reads, must be HTTP compatible
DATABASE_READONLY_URL=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Required for database administration only (DO NOT SHARE THESE)          ║
# ║    You must also have the vars above set                                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Database primary writer (unpooled)
# Used by DB admin scripts (migrate, ingest, etc) for direct access to the writer node
DATABASE_WRITE_URL=

# Invalidate secret token for cache invalidation
# Used to trigger cache invalidation from DB admin scripts after data changes
INVALIDATE_SECRET=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Required for MCP server only (packages/mcp)                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Bearer token for MCP server authentication
# Used by AI agents connecting to the InferenceX MCP endpoint
MCP_SECRET=
